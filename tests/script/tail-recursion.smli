(* Lambda passed out of `let` calls a sibling recursive `fun`.
 * The lambda `fn () => inner ()` captures `inner` from the
 * enclosing `let`. Before the closure-capture fix, the lambda
 * resolved `inner` through the shell-wide link table and lost
 * `inner`'s capture of `x` (see hydromatic/morel-rust#42).
 *)
fun outer x =
  let
    fun inner () = x
  in
    (fn () => inner ()) ()
  end;
> val outer = fn : 'a -> 'a

outer 42;
> val it = 42 : int

(* Pattern 4 from #39: closure captures outer vars.
 * `g4` captures `i` and `fc` from the enclosing `f4`. `g4`
 * itself is not recursive; the recursion goes through `f4`.
 *)
fun f4 (i, fc) =
  let fun g4 j = f4 (i + 1, fc)
  in if i > 3 then 0 else g4 1 end;
> val f4 = fn : int * 'a -> int

f4 (1, fn () => 99);
> val it = 0 : int

(*) End tail-recursion.smli
