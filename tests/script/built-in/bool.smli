 *
 * Unit tests for the built-in `Bool` structure, defined
 * by the Standard ML Basis Library.
 *)
Sys.set ("lineWidth", 78);
> val it = () : unit
Sys.set ("printLength", 999);
> val it = () : unit
Sys.set ("stringDepth", ~1);
> val it = () : unit

Bool;
> val it =
>   {<>=fn,==fn,andalso=fn,fromString=fn,if=fn,implies=fn,not=fn,orelse=fn,
>    toString=fn}
>   : {<>:bool * bool -> bool, =:bool * bool -> bool,
>      andalso:bool * bool -> bool, fromString:string -> bool option,
>      if:bool * 'a * 'a -> 'a, implies:bool * bool -> bool, not:bool -> bool,
>      orelse:bool * bool -> bool, toString:bool -> string}
Bool.fromString;
> val it = fn : string -> bool option
Bool.fromString "true";
> val it = SOME true : bool option
Bool.fromString "false";
> val it = SOME false : bool option
Bool.fromString "yes";
> val it = NONE : bool option
Bool.not;
> val it = fn : bool -> bool
Bool.not true;
> val it = false : bool
Bool.not false;
> val it = true : bool
Bool.`implies`;
> val it = fn : bool * bool -> bool
Bool.`implies` (true, true);
> val it = true : bool
Bool.`implies` (true, false);
> val it = false : bool
Bool.`implies` (false, true);
> val it = true : bool
Bool.`implies` (false, false);
> val it = true : bool
Bool.toString;
> val it = fn : bool -> string
Bool.toString true;
> val it = "true" : string
Bool.toString false;
> val it = "false" : string

(*) End bool.smli
