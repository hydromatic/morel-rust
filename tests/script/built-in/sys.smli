(*) val plan : unit -> string
Sys.plan;
> val it = fn : unit -> string
1 + 2;
> val it = 3 : int
Sys.plan ();
> val it = "apply2(fnValue +, constant(1), constant(2))" : string

(*) val set : string * 'a -> unit
Sys.set;
> val it = fn : string * 'a -> unit
Sys.set ("hybrid", false);
> val it = () : unit
Sys.plan ();
> val it = "apply2(fnValue Sys.set, constant(hybrid), constant(false))" : string

(*) val show : string -> string option
Sys.show;
> val it = fn : string -> string option
show;
> val it = fn : string -> string option
Sys.show "hybrid";
> val it = SOME "false" : string option
Sys.set ("hybrid", true);
> val it = () : unit
Sys.show "hybrid";
> val it = SOME "true" : string option
Sys.show "optionalInt";
> val it = NONE : string option
Sys.plan ();
> val it = "apply(fnValue Sys.show, constant(optionalInt))" : string

(*) val showAll : unit -> string * string option list
Sys.showAll;
> val it = fn : unit -> (string * string option) list
showAll;
> val it = fn : unit -> (string * string option) list
map
  (fn (p,v) =>
    (p, if p = "banner"
          orelse p = "directory"
          orelse p = "productVersion"
          orelse p = "scriptDirectory"
      then SOME "?" else v))
  (Sys.showAll ());
> val it =
>   [("banner",SOME "?"),("directory",SOME "?"),("echo",SOME "false"),
>    ("hybrid",SOME "true"),("idempotent",SOME "false"),
>    ("inlinePassCount",SOME "5"),("lineWidth",SOME "79"),
>    ("matchCoverageEnabled",SOME "true"),("mode",SOME "EVALUATE"),
>    ("now",SOME "2024-01-01T00:00:00Z"),("optionalInt",NONE),
>    ("output",SOME "CLASSIC"),("printDepth",SOME "5"),("printLength",SOME "12"),
>    ("productName",SOME "morel-rust"),("productVersion",SOME "?"),
>    ("relationalize",SOME "false"),("scriptDirectory",SOME "?"),
>    ("showBanner",SOME "true"),("stringDepth",SOME "70"),
>    ("timeZone",SOME "UTC")] : (string * string option) list
List.length (Sys.showAll ());
> val it = 21 : int
List.length (showAll ());
> val it = 21 : int
Sys.plan ();
> val it = "apply(fnValue List.length, argCode apply0(fnValue Sys.showAll))"
>   : string

(*) Test new product properties (MOREL-319)
Sys.show "productName";
> val it = SOME "morel-rust" : string option

(*) Mask version number since it changes with each release
case Sys.show "productVersion" of
  SOME v => String.size v > 0
| NONE => false;
> val it = true : bool

(*) Mask banner since it includes version
case Sys.show "banner" of
  SOME v => String.isPrefix "morel-rust version " v
| NONE => false;
> val it = true : bool

(*) Verify new properties are in showAll
case List.find (fn (p, v) => p = "productName") (Sys.showAll ()) of
  SOME (p, v) => p = "productName"
| NONE => false;
> val it = true : bool

case List.find (fn (p, v) => p = "productVersion") (Sys.showAll ()) of
  SOME (p, v) => p = "productVersion"
| NONE => false;
> val it = true : bool

case List.find (fn (p, v) => p = "banner") (Sys.showAll ()) of
  SOME (p, v) => p = "banner"
| NONE => false;
> val it = true : bool

Sys.set ("optionalInt", ~5);
> val it = () : unit
Sys.show "optionalInt";
> val it = SOME "-5" : string option

(*) val unset : string -> unit
Sys.unset;
> val it = fn : string -> unit
Sys.unset "hybrid";
> val it = () : unit
Sys.unset "optionalInt";
> val it = () : unit
Sys.plan ();
> val it = "apply(fnValue Sys.unset, constant(optionalInt))" : string

(*) End sys.smli
