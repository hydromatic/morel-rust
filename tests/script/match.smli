 * Pattern matching
 *)

(*) Warning: match nonexhaustive
fun f 1 = 0;
> stdIn:1.5-1.12 Warning: match nonexhaustive
>   raised at: stdIn:1.5-1.12
> val f = fn : int -> int
f 1;
> val it = 0 : int
f 2;
> uncaught exception Match [nonexhaustive match failure]
>   raised at: stdIn:1.5-1.12

(*) Three forms that all reach a non-exhaustive pattern at runtime,
(*) showing the difference between the 'Bind' exception (raised by a
(*) failing 'val' binding) and the 'Match' exception (raised by a
(*) failing function application).

(*) 'val' with a non-exhaustive pattern raises 'Bind'.
val (1, x) = (2, 3);
> uncaught exception Bind [nonexhaustive binding failure]
>   raised at: stdIn:1.5-1.20

(*) 'fun' with a non-exhaustive pattern: defining is OK (warning),
(*) but applying it to a non-matching value raises 'Match'.
fun f1 (1, x) = 3;
> stdIn:1.5-1.18 Warning: match nonexhaustive
>   raised at: stdIn:1.5-1.18
> val f1 = fn : int * 'a -> int
f1 (2, 3);
> uncaught exception Match [nonexhaustive match failure]
>   raised at: stdIn:1.5-1.18

(*) 'val ... = fn' with the same body behaves the same as 'fun'.
val g1 = fn (1, x) => 3;
> stdIn:1.10-1.24 Warning: match nonexhaustive
>   raised at: stdIn:1.10-1.24
> val g1 = fn : int * 'a -> int
g1 (2, 3);
> uncaught exception Match [nonexhaustive match failure]
>   raised at: stdIn:1.10-1.24

(*) Warning: match nonexhaustive, twice
fun f x =
  let
    fun g 1 = 1
    and h 2 = 2
  in
    (g x) + (h 2)
  end;
> stdIn:3.9-4.5 Warning: match nonexhaustive
>   raised at: stdIn:3.9-4.5
> stdIn:4.9-5.3 Warning: match nonexhaustive
>   raised at: stdIn:4.9-5.3
> val f = fn : int -> int
f 1;
> val it = 3 : int
f 2;
> uncaught exception Match [nonexhaustive match failure]
>   raised at: stdIn:3.9-4.5

(*) Error: match redundant and nonexhaustive
fun f 1 = 0
  | f 1 = 0;
> stdIn:2.5-2.12 Error: match redundant and nonexhaustive
>   raised at: stdIn:2.5-2.12

(*) OK
fun f 1 = 0
  | f _ = 1;
> val f = fn : int -> int
f 1;
> val it = 0 : int
f 2;
> val it = 1 : int

(*) Error: match redundant
fun f (1, _) = 1
  | f (_, 2) = 2
  | f (1, 2) = 3
  | f (_, _) = 4;
> stdIn:3.5-4.3 Error: match redundant
>   raised at: stdIn:3.5-4.3

(*) Exhaustive match on a user-defined datatype
datatype color = Red | Green | Blue;
> datatype color = Red | Green | Blue
fun name Red = "red"
  | name Green = "green"
  | name Blue = "blue";
> val name = fn : color -> string
name Red;
> val it = "red" : string
name Blue;
> val it = "blue" : string

(*) Non-exhaustive match on a user-defined datatype
fun warm Red = true;
> stdIn:1.5-1.20 Warning: match nonexhaustive
>   raised at: stdIn:1.5-1.20
> val warm = fn : color -> bool
warm Red;
> val it = true : bool
warm Green;
> uncaught exception Match [nonexhaustive match failure]
>   raised at: stdIn:1.5-1.20

(*) The Ackermann-Péter function
(*) See "Recursion Equations as a Programming Language", D A Turner 1982
fun ack 0 n = n + 1
  | ack m 0 = ack (m - 1) 1
  | ack m n = ack (m - 1) (ack m (n - 1));
> val ack = fn : int -> int -> int
ack 0 0;
> val it = 1 : int
ack 0 1;
> val it = 2 : int
ack 1 0;
> val it = 2 : int
ack 1 2;
> val it = 4 : int
ack 2 3;
> val it = 9 : int
set("mode", "validate");
> val it = () : unit
(* Disabled because of stack overflow. ack m (n-1) is not in tail
 * position (its result is consumed as the second arg of an outer
 * call), so TCO #151 alone does not help. *)
ack 3 3;
> val it = 61 : int
set("mode", "evaluate");
> val it = () : unit

(* Various types, exhaustive & non-exhaustive --------------------- *)
(*) From https://smlhelp.github.io/book/docs/start/syntax/

(*) unit, exhaustive
(fn () => ());
> val it = fn : unit -> unit

(*) bool, non-exhaustive
(fn true => 1);
> stdIn:1.1-1.15 Warning: match nonexhaustive
>   raised at: stdIn:1.1-1.15
> val it = fn : bool -> int

(*) bool, exhaustive
(fn true  => 1
  | false => 0);
> val it = fn : bool -> int

(*) order, non-exhaustive
(fn LESS => ~1);
> stdIn:1.1-1.16 Warning: match nonexhaustive
>   raised at: stdIn:1.1-1.16
> val it = fn : order -> int

(*) order, non-exhaustive
(fn LESS  => ~1
  | EQUAL => 0);
> stdIn:1.1-2.16 Warning: match nonexhaustive
>   raised at: stdIn:1.1-2.16
> val it = fn : order -> int

(*) order, exhaustive
(fn LESS    => ~1
  | EQUAL   => 0
  | GREATER => 1);
> val it = fn : order -> int

(*) int, non-exhaustive
(fn 0 => true);
> stdIn:1.1-1.15 Warning: match nonexhaustive
>   raised at: stdIn:1.1-1.15
> val it = fn : int -> bool

(*) order, exhaustive
(fn 0 => true
  | _ => false);
> val it = fn : int -> bool

(*) int list, non-exhaustive
(fn x::_ => x + 1);
> stdIn:1.1-1.19 Warning: match nonexhaustive
>   raised at: stdIn:1.1-1.19
> val it = fn : int list -> int

(*) int list, exhaustive
(fn [] => 0
  | x::_ => x + 1);
> val it = fn : int list -> int

(*) int * bool, non-exhaustive
(fn (0,b) => true andalso b);
> stdIn:1.1-1.29 Warning: match nonexhaustive
>   raised at: stdIn:1.1-1.29
> val it = fn : int * bool -> bool

(*) int * bool, exhaustive
(fn (0,b) => true andalso b
  | (n,_) => false);
> val it = fn : int * bool -> bool

(* Exhaustive function of option list ----------------------------- *)

(*) Non-exhaustive function
fun f [(SOME i)] = i
  | f [] = 0;
> stdIn:1.5-2.13 Warning: match nonexhaustive
>   raised at: stdIn:1.5-2.13
> val f = fn : int option list -> int

(*) Add NONE, still non-exhaustive
fun f [(SOME i)] = i
  | f [NONE] = ~1
  | f [] = 0;
> stdIn:1.5-3.13 Warning: match nonexhaustive
>   raised at: stdIn:1.5-3.13
> val f = fn : int option list -> int

(*) Allow list longer than 1, still non-exhaustive
fun f [(SOME i)] = i
  | f [] = 0
  | f (one :: two :: rest) = ~2;
> stdIn:1.5-3.32 Warning: match nonexhaustive
>   raised at: stdIn:1.5-3.32
> val f = fn : int option list -> int

(*) Exhaustive
fun f [(SOME i)] = i
  | f [NONE] = ~1
  | f [] = 0
  | f (one :: two :: rest) = ~2;
> val f = fn : int option list -> int

(*) End match.smli
